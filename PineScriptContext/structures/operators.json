    "expr1 * expr2"
  ],
  "*=": [
    "expr1 *= expr2"
  ],
  "/": [
    "expr1 / expr2"
  ],
  "/=": [
    "expr1 /= expr2"
  ],
  "%": [
    "expr1 % expr2"
  ],
  "%=": [
    "expr1 %= expr2"
  ],
  "+": [
    "expr1 + expr2"
  ],
  "+=": [
    "expr1 += expr2"
  ],
  "<": [
    "expr1 < expr2"
  ],
  "<=": [
    "expr1 <= expr2"
  ],
  "==": [
    "expr1 == expr2"
