{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["vitest/globals"]
  },
  "include": [
    "pynescript/**/*.ts",
    "**/*.ts"
  ],
  "exclude": [
    "tests/**/*",
    "scripts/**/*",
    "PineScriptContext/**/*",
    "api-coverage-analysis.ts"
  ]
}
